# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model used for answer generation
ANTHROPIC_MODEL=claude-opus-4-8

# Storage locations
CHROMA_DIR=./data/chroma
UPLOAD_DIR=./data/uploads

# Retrieval / chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=10
